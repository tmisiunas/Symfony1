{% extends 'base.html.twig' %}

{% block title %}Tmp index{% endblock %}

{% block body %}
    <h1>Tmp index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for tmp in tmps %}
            <tr>
                <td>{{ tmp.id }}</td>
                <td>{{ tmp.name }}</td>
                <td>
                    <a href="{{ path('app_tmp_show', {'id': tmp.id}) }}">show</a>
                    <a href="{{ path('app_tmp_edit', {'id': tmp.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_tmp_new') }}">Create new</a>
{% endblock %}
