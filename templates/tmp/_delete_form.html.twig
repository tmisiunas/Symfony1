<form method="post" action="{{ path('app_tmp_delete', {'id': tmp.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tmp.id) }}">
    <button class="btn btn-danger" onclick="return confirm('Are you sure?')">
        Delete
    </button>
</form>
