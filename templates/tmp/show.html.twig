{% extends 'base.html.twig' %}

{% block title %}Tmp{% endblock %}

{% block body %}
    <h1>Tmp</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ tmp.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ tmp.name }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ tmp.description }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_tmp_index') }}" class="btn btn-secondary mt-3">Back</a>

    </br></br>

    <a href="{{ path('app_tmp_edit', {'id': tmp.id}) }}" class="btn btn-sm btn-warning">Edit</a>

    </br></br>

    {{ include('tmp/_delete_form.html.twig') }}

{% endblock %}
